<UserControl x:Class="SmartRenamer.Controls.ConversationCards.FolderPickerCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border
        Margin="5"
        Padding="15"
        CornerRadius="10"
        BorderBrush="#D0D0D0"
        BorderThickness="1"
        Background="#F8F8F8">

        <StackPanel>

            <TextBlock
                FontSize="18"
                FontWeight="Bold"
                Text="📁 Project Location"/>

            <TextBlock
                Margin="0,10,0,15"
                TextWrapping="Wrap"
                Text="Show me the folder you'd like us to work on together."/>

            <Button
                Width="160"
                Height="35"
                HorizontalAlignment="Left"
                Content="Choose Folder"/>

        </StackPanel>

    </Border>

</UserControl>