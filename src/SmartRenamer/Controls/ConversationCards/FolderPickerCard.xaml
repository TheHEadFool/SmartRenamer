<UserControl x:Class="SmartRenamer.Controls.ConversationCards.FolderPickerCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Margin="5"
            Padding="15"
            CornerRadius="10"
            BorderBrush="#D6D6D6"
            BorderThickness="1"
            Background="#F8F8F8">

        <StackPanel>

            <TextBlock FontSize="18"
                       FontWeight="SemiBold"
                       Text="📁 Project Location"/>

            <TextBlock Margin="0,10,0,15"
                       TextWrapping="Wrap"
                       Text="I'll take a quick look around before we decide what to do."/>

            <Button Width="170"
                    Height="36"
                    HorizontalAlignment="Left"
                    Content="Choose Folder"
                    Command="{Binding ChooseFolderCommand}"/>

        </StackPanel>

    </Border>

</UserControl>