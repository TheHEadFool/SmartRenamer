<UserControl x:Class="SmartRenamer.Controls.ConversationCards.WelcomeCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border
        Background="White"
        BorderBrush="#D8DEE8"
        BorderThickness="1"
        CornerRadius="18"
        Padding="25"
        Margin="15">

        <StackPanel>

            <TextBlock
                FontSize="36"
                HorizontalAlignment="Center"
                Text="👋"/>

            <TextBlock
                Margin="0,15,0,0"
                FontSize="24"
                FontWeight="SemiBold"
                HorizontalAlignment="Center"
                Text="Welcome"/>

            <TextBlock
                Margin="0,20,0,0"
                FontSize="15"
                TextWrapping="Wrap"
                TextAlignment="Center">

Welcome, I am Scout and 

I'm here to help organize your photos, movies, books,
music, documents, downloads,
and anything else.

            </TextBlock>

            <Separator Margin="0,20"/>

            <TextBlock
                FontSize="18"
                FontWeight="SemiBold"
                Text="Before we begin..."/>

            <TextBlock
                Margin="0,12,0,20"
                TextWrapping="Wrap"
                Text="What would you like me to call you?"/>

            <TextBox
                Height="38"/>

            <Button
                Margin="0,20,0,0"
                Height="40"
                Width="130"
                HorizontalAlignment="Center"
                Content="Continue"/>

        </StackPanel>

    </Border>

</UserControl>