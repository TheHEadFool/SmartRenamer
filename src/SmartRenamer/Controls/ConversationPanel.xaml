<UserControl x:Class="SmartRenamer.Controls.ConversationPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:cards="clr-namespace:SmartRenamer.Controls.ConversationCards">

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Conversation -->

        <ListBox Grid.Row="0"
                 ItemsSource="{Binding Conversation.Messages}"
                 BorderThickness="0"
                 Background="Transparent">

            <ListBox.ItemTemplate>

                <DataTemplate>

                    <Border Margin="5"
                            Padding="10"
                            CornerRadius="10"
                            Background="#EEEEEE">

                        <StackPanel>

                            <TextBlock FontWeight="Bold"
                                       Text="Guide"/>

                            <TextBlock Margin="0,5,0,0"
                                       Text="{Binding Text}"
                                       TextWrapping="Wrap"/>

                        </StackPanel>

                    </Border>

                </DataTemplate>

            </ListBox.ItemTemplate>

        </ListBox>

        <!-- Temporary Folder Picker Card -->

        <cards:FolderPickerCard
            Grid.Row="1"
            Margin="0,10,0,10"/>

        <!-- Input -->

        <DockPanel Grid.Row="2">

            <TextBox Width="250"
                     Text="{Binding UserInput,
                                    UpdateSourceTrigger=PropertyChanged}" />

            <Button Margin="10,0,0,0"
                    Width="90"
                    Content="Continue"
                    Command="{Binding SendCommand}" />

        </DockPanel>

    </Grid>

</UserControl>