<UserControl x:Class="SmartRenamer.Controls.StepCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="150"
             Width="250">

    <Border Margin="8"
            Padding="12"
            CornerRadius="10"
            BorderBrush="DarkGray"
            BorderThickness="1"
            Background="White">

        <StackPanel>

            <TextBlock
                Text="🔤"
                FontSize="28"
                HorizontalAlignment="Center"/>

            <TextBlock
                Text="Find &amp; Replace"
                FontSize="18"
                FontWeight="Bold"
                Margin="0,8,0,0"
                HorizontalAlignment="Center"/>

            <TextBlock
                Text="Replace text inside filenames."
                TextWrapping="Wrap"
                Margin="0,10,0,0"
                HorizontalAlignment="Center"
                TextAlignment="Center"/>

            <Border Margin="0,12,0,0"
                    Background="#EEEEEE"
                    CornerRadius="6"
                    Padding="4">

                <TextBlock
                    Text="Text"
                    HorizontalAlignment="Center"
                    FontWeight="SemiBold"/>

            </Border>

        </StackPanel>

    </Border>

</UserControl>