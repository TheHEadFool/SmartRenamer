<UserControl x:Class="SmartRenamer.Controls.WorkflowCanvas"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:SmartRenamer.Controls">

    <Border Background="#F5F5F5"
            BorderBrush="#CCCCCC"
            BorderThickness="1"
            CornerRadius="6"
            Padding="15">

        <ScrollViewer VerticalScrollBarVisibility="Auto">

            <StackPanel>

                <TextBlock
                    Text="Workflow"
                    FontSize="22"
                    FontWeight="Bold"
                    Margin="0,0,0,15"/>

                <controls:StepCard/>

            </StackPanel>

        </ScrollViewer>

    </Border>

</UserControl>