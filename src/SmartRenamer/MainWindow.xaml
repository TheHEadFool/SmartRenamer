<Window x:Class="SmartRenamer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SmartRenamer"
        Height="700"
        Width="1100"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal"
            Margin="0,0,0,10">

            <Button Width="120"
            Height="35"
            Margin="0,0,10,0"
            Click="AddFiles_Click">
                Add Files
            </Button>

            <TextBlock VerticalAlignment="Center"
               Margin="10,0,5,0">
        Find:
            </TextBlock>

            <TextBox x:Name="FindTextBox"
             Width="180"
             Margin="0,0,10,0"/>

            <TextBlock VerticalAlignment="Center"
               Margin="0,0,5,0">
        Replace:
            </TextBlock>

            <TextBox x:Name="ReplaceTextBox"
             Width="180"
             Margin="0,0,10,0"/>

            <Button Width="120"
            Height="35"
            Margin="0,0,10,0"
            Click="Preview_Click">
                Preview
            </Button>

            <Button Width="120"
        Height="35"
        Click="Rename_Click">
                Rename
            </Button>

        </StackPanel>

        <DataGrid Grid.Row="1"
          ItemsSource="{Binding Files}"
          AutoGenerateColumns="False">

            <DataGrid.Columns>

                <DataGridTextColumn Header="Current Name"
                            Binding="{Binding CurrentName}"
                            Width="*" />

                <DataGridTextColumn Header="New Name"
                            Binding="{Binding NewName}"
                            Width="*" />

                <DataGridTextColumn Header="Status"
                            Binding="{Binding Status}"
                            Width="150" />

            </DataGrid.Columns>

        </DataGrid>

        <StatusBar Grid.Row="2">

            <StatusBarItem>

                <TextBlock>
                    Ready
                </TextBlock>

            </StatusBarItem>

        </StatusBar>

    </Grid>

</Window>