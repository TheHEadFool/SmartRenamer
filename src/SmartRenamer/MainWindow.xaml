<Window x:Class="SmartRenamer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:SmartRenamer.Controls"
        Title="SmartRenamer"
        Height="800"
        Width="1300"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="350"/>
        </Grid.ColumnDefinitions>

        <!-- Building Blocks -->

        <GroupBox Header="Building Blocks"
                  Margin="5">

            <StackPanel Margin="10">

                <Button Content="🔤 Find &amp; Replace" Margin="0,0,0,5"/>
                <Button Content="📁 Move Files" Margin="0,0,0,5"/>
                <Button Content="📷 Read EXIF" Margin="0,0,0,5"/>
                <Button Content="🤖 AI Describe" Margin="0,0,0,5"/>
                <Button Content="🔢 Regex"/>

            </StackPanel>

        </GroupBox>

        <!-- Workflow -->

        <controls:WorkflowCanvas
            Grid.Column="1"
            Margin="5"/>

        <!-- Guide -->

        <GroupBox Header="Guide"
                  Grid.Column="2"
                  Margin="5">

            <controls:ConversationPanel
                DataContext="{Binding Guide}" />

        </GroupBox>

    </Grid>

</Window>