<Window x:Class="SmartRenamer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:SmartRenamer.Controls"
        Title="Scout"
        Width="1650"
        Height="900"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->

        <Border Grid.Row="0"
                Margin="0,0,0,20"
                Padding="20"
                CornerRadius="18"
                Background="{StaticResource PrimaryBrush}">

            <StackPanel>

                <TextBlock
    Text="Scout"
    FontSize="34"
    FontWeight="Bold"
    Foreground="White"/>

                <TextBlock
    Margin="0,6,0,0"
    Text="Your Guide on This File Safari"
    FontSize="16"
    Foreground="#DDE8FF"/>

            </StackPanel>

        </Border>

        <!-- Main -->

        <Grid Grid.Row="1">

            <Grid.ColumnDefinitions>

                <ColumnDefinition Width="270"/>

                <ColumnDefinition Width="*"/>

                <ColumnDefinition Width="560"/>

            </Grid.ColumnDefinitions>

            <!-- ================================================= -->
            <!-- Scout Observations -->
            <!-- ================================================= -->

            <Border Grid.Column="0"
        Style="{StaticResource CardBorder}">

                <ScrollViewer VerticalScrollBarVisibility="Auto">

                    <StackPanel Margin="15">

                        <TextBlock
    FontSize="22"
    FontWeight="Bold"
    Text="Scout"/>

                        <TextBlock
    Margin="0,6,0,20"
    Foreground="{StaticResource SecondaryTextBrush}"
    Text="Choose an observation to explore."/>

                        <Border
                Padding="16"
                CornerRadius="12"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                Background="#F8FAFD">

                            <StackPanel>

                                <ItemsControl ItemsSource="{Binding Workspace.Observations}">

                                    <ItemsControl.ItemTemplate>

                                        <DataTemplate>

                                            <Border
        Margin="0,0,0,10"
        Padding="8"
        CornerRadius="8"
        Background="#EEF5FF">

                                                <StackPanel>

                                                    <TextBlock
                Text="⭐ Scout Recommends"
                FontSize="11"
                FontWeight="Bold"
                Foreground="DarkGoldenrod"
                Visibility="{Binding IsRecommended,
                    Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                                    <Button
                Margin="0,4,0,0"
                Padding="8,4"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Left"
                Content="{Binding Title}"
                Command="{Binding DataContext.Workspace.SelectObservationCommand,
                          RelativeSource={RelativeSource AncestorType=Window}}"
                CommandParameter="{Binding}"/>

                                                </StackPanel>

                                            </Border>

                                        </DataTemplate>

                                    </ItemsControl.ItemTemplate>

                                </ItemsControl>

                                <TextBlock
    Margin="0,12,0,0"
    TextWrapping="Wrap"
    Foreground="{StaticResource SecondaryTextBrush}"
    Text="{Binding Workspace.SelectedObservation.Description}"/>

                                <TextBlock
    Margin="0,12,0,20"
    TextWrapping="Wrap"
    Foreground="{StaticResource SecondaryTextBrush}"
    Text="{Binding Workspace.SelectedObservation.WhyItMatters}"/>
                                <ItemsControl
                        ItemsSource="{Binding Workspace.Recommendations}">

                                    <ItemsControl.ItemTemplate>

                                        <DataTemplate>

                                            <Button
                                    Margin="0,0,0,10"
                                    Padding="14,8"
                                    HorizontalAlignment="Stretch"
                                    Visibility="{Binding HasAction,
                                        Converter={StaticResource BooleanToVisibilityConverter}}"
                                    Content="{Binding ActionText}"
                                    Command="{Binding DataContext.ExecuteRecommendationCommand,
                                              RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}" />

                                        </DataTemplate>

                                    </ItemsControl.ItemTemplate>

                                </ItemsControl>

                            </StackPanel>

                        </Border>

                    </StackPanel>

                </ScrollViewer>

            </Border>
            <!-- ================================================= -->
            <!-- Workspace -->
            <!-- ================================================= -->

            <Border Grid.Column="1"
                    Margin="20,0"
                    Style="{StaticResource CardBorder}">

                <Grid Margin="25">

                    <Grid.RowDefinitions>

                        <RowDefinition Height="Auto"/>

                        <RowDefinition Height="Auto"/>

                        <RowDefinition Height="25"/>

                        <RowDefinition Height="*"/>

                        <RowDefinition Height="25"/>

                        <RowDefinition Height="*"/>

                    </Grid.RowDefinitions>

                    <TextBlock
    Grid.Row="0"
    FontSize="30"
    FontWeight="Bold"
    Text="The Plan"/>

                    <TextBlock
                        Grid.Row="1"
                        Margin="0,8,0,0"
                        FontSize="16"
                        Foreground="{StaticResource SecondaryTextBrush}"
                        Text="{Binding Workspace.Description}"/>

                    <StackPanel Grid.Row="3">

                        <TextBlock
                            FontSize="20"
                            FontWeight="SemiBold"
                            Text="Planned Actions"/>

                        <ItemsControl
                            Margin="0,15,0,0"
                            ItemsSource="{Binding Workspace.Observations}">

                            <ItemsControl.ItemTemplate>

                                <DataTemplate>

                                    <Border
                                        Margin="0,0,0,10"
                                        Padding="12"
                                        Background="#EEF5FF"
                                        CornerRadius="10">

                                        <TextBlock
    FontWeight="SemiBold"
    Text="{Binding ActionTitle}"
    TextWrapping="Wrap"/>

                                    </Border>

                                </DataTemplate>

                            </ItemsControl.ItemTemplate>

                        </ItemsControl>

                    </StackPanel>

                    <Grid Grid.Row="5">

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" LastChildFill="False">

                            <TextBlock
            FontSize="20"
            FontWeight="SemiBold"
            Text="Rename Preview"/>

                            <Border
            Margin="10,0,0,0"
            Padding="8,2"
            Background="#D9EEF8"
            CornerRadius="10"
            DockPanel.Dock="Right">

                                <TextBlock
                FontWeight="SemiBold"
                Text="{Binding Workspace.RenameCount,
                               StringFormat={}{0} file(s)}"/>

                            </Border>

                        </DockPanel>

                        <Border
        Grid.Row="1"
        Margin="0,15,0,0"
        BorderBrush="#D8D8D8"
        BorderThickness="1"
        CornerRadius="8">

                            <DataGrid
            AutoGenerateColumns="False"
            CanUserAddRows="False"
            CanUserDeleteRows="False"
            CanUserResizeRows="False"
            HeadersVisibility="Column"
            IsReadOnly="True"
            GridLinesVisibility="Horizontal"
            ScrollViewer.VerticalScrollBarVisibility="Auto"
            ScrollViewer.HorizontalScrollBarVisibility="Auto"
            ItemsSource="{Binding Workspace.RenamePreview}">

                                <DataGrid.Columns>

                                    <DataGridTextColumn
                    Header="Current Name"
                    Width="*"
                    Binding="{Binding CurrentName}" />

                                    <DataGridTextColumn
                    Header="New Name"
                    Width="*"
                    Binding="{Binding NewName}" />

                                </DataGrid.Columns>

                            </DataGrid>

                        </Border>

                    </Grid>

                </Grid>

            </Border>

            <!-- ================================================= -->
            <!-- Scout -->
            <!-- ================================================= -->

            <Border Grid.Column="2"
                    Style="{StaticResource CardBorder}">

                <controls:ConversationPanel
                    DataContext="{Binding Guide}"/>

            </Border>

        </Grid>

        <!-- Status -->

        <Border Grid.Row="2"
                Margin="0,20,0,0"
                Padding="12"
                CornerRadius="10"
                Background="White"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1">

            <DockPanel>

                <TextBlock
                    FontWeight="SemiBold"
                    Text="Ready"/>

                <TextBlock
                    HorizontalAlignment="Right"
                    Foreground="{StaticResource SecondaryTextBrush}"
                    Text="Version 0.5 Development"/>

            </DockPanel>

        </Border>

    </Grid>

</Window>