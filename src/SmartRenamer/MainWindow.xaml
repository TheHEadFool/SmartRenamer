<Window x:Class="SmartRenamer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SmartRenamer"
        Height="700"
        Width="1100"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">

            <Button Width="120"
            Height="35"
            Margin="0,0,10,0"
            Command="{Binding AddFilesCommand}"
            Content="Add Files" />

            <TextBlock VerticalAlignment="Center"
               Margin="10,0,5,0"
               Text="Find:" />

            <TextBox Width="180"
             Margin="0,0,10,0"
             Text="{Binding FindText, UpdateSourceTrigger=PropertyChanged}" />

            <TextBlock VerticalAlignment="Center"
               Margin="0,0,5,0"
               Text="Replace:" />

            <TextBox Width="180"
             Margin="0,0,10,0"
             Text="{Binding ReplaceText, UpdateSourceTrigger=PropertyChanged}" />

            <Button Width="120"
            Height="35"
            Margin="0,0,10,0"
            Command="{Binding PreviewCommand}"
            Content="Preview" />

            <Button Width="120"
            Height="35"
            Command="{Binding RenameCommand}"
            Content="Rename" />

        </StackPanel>

        <DataGrid Grid.Row="1"
          ItemsSource="{Binding Files}"
          AutoGenerateColumns="False">

            <DataGrid.Columns>

                <DataGridTextColumn Header="Current Name"
                            Binding="{Binding CurrentName}"
                            Width="*" />

                <DataGridTextColumn Header="New Name"
                            Binding="{Binding NewName}"
                            Width="*" />

                <DataGridTextColumn Header="Status"
                            Binding="{Binding Status}"
                            Width="150" />

            </DataGrid.Columns>

        </DataGrid>

        <StatusBar Grid.Row="2">

            <StatusBarItem>

                <TextBlock>
                    Ready
                </TextBlock>

            </StatusBarItem>

        </StatusBar>

    </Grid>

</Window>